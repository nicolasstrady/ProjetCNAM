<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>

<AnchorPane fx:id="root"
            prefWidth="900" prefHeight="500"
            style="-fx-background-image: url('/sample/img/background.jpg');
                   -fx-background-repeat: no-repeat;
                   -fx-background-size: cover;
                   -fx-background-position: center center;"
            xmlns="http://javafx.com/javafx/11.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="sample.PartieController">

   <!-- Top status label -->
   <Label fx:id="statusLabel"
          text="Tour 1"
          alignment="CENTER"
          style="-fx-text-fill: white;
                  -fx-font-size: 1.5em;
                  -fx-background-color: rgba(0,0,0,0.5);
                  -fx-padding: 5;
                  -fx-background-radius: 5;"
          AnchorPane.topAnchor="10"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0" />

   <!-- Main content area -->
   <VBox AnchorPane.topAnchor="60"
         AnchorPane.bottomAnchor="150"
         AnchorPane.leftAnchor="20"
         AnchorPane.rightAnchor="20"
         spacing="20">

      <!-- Opponents row -->
      <HBox fx:id="hboxTop"
            alignment="CENTER"
            spacing="40">
         <Region HBox.hgrow="ALWAYS" />
         <VBox alignment="CENTER" spacing="5">
            <Label fx:id="labelTopLeft" style="-fx-text-fill: white; -fx-font-size: 1em; -fx-font-weight: bold;" />
            <Label fx:id="scoreTopLeft" style="-fx-text-fill: white;" />
            <ImageView fitWidth="60" fitHeight="100" preserveRatio="true">
               <image><Image url="@img/carte.png"/></image>
            </ImageView>
         </VBox>
          <HBox fx:id="teamScoreBox" alignment="CENTER" spacing="10.0" visible="false" style="-fx-background-color: rgba(0,0,0,0.5); -fx-padding: 5; -fx-background-radius: 5;">
              <children>
                  <Label fx:id="attackScoreLabel" style="-fx-text-fill: red; -fx-font-size: 18px; -fx-font-weight: bold;" />
                  <Label text="|" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />
                  <Label fx:id="defenseScoreLabel" style="-fx-text-fill: blue; -fx-font-size: 18px; -fx-font-weight: bold;" />
              </children>
          </HBox>
         <VBox alignment="CENTER" spacing="5">
            <Label fx:id="labelTopRight" style="-fx-text-fill: white; -fx-font-size: 1em; -fx-font-weight: bold;" />
            <Label fx:id="scoreTopRight" style="-fx-text-fill: white;" />
            <ImageView fitWidth="60" fitHeight="100" preserveRatio="true">
               <image><Image url="@img/carte.png"/></image>
            </ImageView>
         </VBox>
         <Region HBox.hgrow="ALWAYS" />
      </HBox>

      <!-- Bottom row: left player, actions, right player -->
      <HBox fx:id="hboxBottom"
            alignment="CENTER"
            spacing="20">
         <!-- Left spacer -->
         <Region HBox.hgrow="ALWAYS" />

         <!-- Left player -->
         <VBox alignment="CENTER" spacing="5">
            <Label fx:id="labelLeft" style="-fx-text-fill: white; -fx-font-size: 1em; -fx-font-weight: bold;" />
            <Label fx:id="scoreLeft" style="-fx-text-fill: white;" />
            <ImageView fitWidth="60" fitHeight="100" preserveRatio="true">
               <image><Image url="@img/carte.png"/></image>
            </ImageView>
         </VBox>

         <!-- Middle spacer between left and actions -->
         <Region HBox.hgrow="ALWAYS" />

         <!-- Action buttons & central card area -->
         <Button fx:id="take" text="Prendre le chien" onAction="#playWithDog" visible="false" />
         <StackPane prefWidth="200" prefHeight="200">
            <HBox fx:id="boxTour" alignment="CENTER" spacing="10" />
            <HBox fx:id="boxChien" alignment="CENTER" spacing="20" />
            <ImageView fx:id="carteCenter" fitWidth="60" fitHeight="100" preserveRatio="true" />
            <HBox fx:id="boxRois" alignment="CENTER" />
            <Button fx:id="retrieveDog" text="Récupérer" onAction="#retrieveDogCards" visible="false" StackPane.alignment="BOTTOM_CENTER"/>
         </StackPane>
         <Button fx:id="refuse" text="Refuser le chien" onAction="#playWithoutDog" visible="false" />

         <!-- Middle spacer between actions and right player -->
         <Region HBox.hgrow="ALWAYS" />

         <!-- Right player -->
         <VBox alignment="CENTER" spacing="5">
            <Label fx:id="labelRight" style="-fx-text-fill: white; -fx-font-size: 1em; -fx-font-weight: bold;" />
            <Label fx:id="scoreRight" style="-fx-text-fill: white;" />
            <ImageView fitWidth="60" fitHeight="100" preserveRatio="true">
               <image><Image url="@img/carte.png"/></image>
            </ImageView>
         </VBox>

         <!-- Right spacer -->
         <Region HBox.hgrow="ALWAYS" />
      </HBox>

   </VBox>

   <!-- Self score at bottom center -->
   <Label fx:id="scoreSelf" alignment="CENTER" style="-fx-text-fill: white;"
          AnchorPane.bottomAnchor="130"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0" />

   <!-- Player hand or dynamic cards -->
   <FlowPane fx:id="main"
             AnchorPane.bottomAnchor="10"
             AnchorPane.leftAnchor="20"
             AnchorPane.rightAnchor="20"
             hgap="10"
             vgap="10"
             alignment="CENTER"/>

</AnchorPane>
